{
  "name": "ez-edge-cms",
  "version": "0.1.19",
  "description": "A KV-backed, no-code CMS for Cloudflare Workers.",
  "author": "Evgenii Zinner",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "dev:test": "powershell -ExecutionPolicy Bypass -File tests/e2e/run-test-server.ps1",
    "test:unit": "bun test tests/unit",
    "test:e2e": "playwright test",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "docs": "typedoc",
    "release": "bun run scripts/release.ts",
    "release:minor": "bun run scripts/release.ts minor",
    "release:patch": "bun run scripts/release.ts patch",
    "release:major": "bun run scripts/release.ts major"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240208.0",
    "@iconify-json/carbon": "^1.2.19",
    "@playwright/test": "^1.58.2",
    "@unocss/core": "^66.6.2",
    "@unocss/preset-attributify": "^66.6.2",
    "@unocss/preset-icons": "^66.6.2",
    "@unocss/preset-uno": "^66.6.2",
    "@unocss/preset-web-fonts": "^66.6.2",
    "@unocss/preset-wind4": "^66.6.2",
    "bun-types": "^1.3.9",
    "prettier": "3.8.1",
    "typedoc": "^0.28.17",
    "unocss": "^66.6.2",
    "wrangler": "^4.72.0"
  }
}
